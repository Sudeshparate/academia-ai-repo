# Root .gitignore for academia-ai

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
env/
venv/
ENV/
.env
.env.*
.Python

# IDEs
.vscode/

# PyTorch / model artifacts
*.pt
*.pth
*.ckpt
*.h5
*.bin
*.model
models/
model_weights/
checkpoints/

# Data / uploads
uploads/
data/
*.csv
*.jsonl
*.parquet

# Logs
*.log
logs/

# Audio / video / temp chunks
*.wav
*.mp4
*.mov
*.avi
*.mkv
chunks/
*.chunk.wav

# Node / frontend
/frontend/node_modules/
/frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# OS files
.DS_Store
Thumbs.db

# Git LFS attributes
.gitattributes

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Temporary and swap
*.tmp
*.swp

# Secrets and keys
secrets/
*.key
